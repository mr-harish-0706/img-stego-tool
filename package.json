{
  "name": "imgstego",
  "version": "1.1.0",
  "description": "Desktop steganography tool to hide and extract messages in PNG images using LSB algorithm",
  "main": "src/main/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --win"
  },
  "keywords": [
    "steganography",
    "cybersecurity",
    "electron",
    "lsb"
  ],
  "author": "Harish Sekar",
  "license": "ISC",
  "devDependencies": {
    "electron": "32.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "pako": "^2.1.0",
    "pngjs": "^7.0.0"
  },
  "build": {
    "appId": "com.imgstego.app",
    "productName": "ImgStego",
    "directories": {
      "output": "/dist/"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
